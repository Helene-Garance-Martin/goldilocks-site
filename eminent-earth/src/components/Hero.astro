---
---

<section class="hero">
  <div class="left">
    <span class="eyebrow">lineage · traversal · topology</span>
    <h1>from DAG<br/>to RAG<br/><span class="accent">to riches.</span></h1>
    <p class="tagline">Graph your pipeline lineage. Traverse the DAG. Ask what it means. Structure that was always there — now visible.</p>
    <a href="https://pypi.org/project/goldilocks-curls" class="cta">pip install goldilocks-curls →</a>
  </div>

  <div class="terminal">
    <div class="term-bar">
      <span class="dot red"></span>
      <span class="dot grey"></span>
      <span class="dot gold"></span>
      <span class="term-title">goldilocks</span>
    </div>
    <div class="term-body">
      <div class="lines" id="termLines"></div>
    </div>
    <div class="term-footer">love your cURLs &nbsp;·&nbsp; 🫧</div>
  </div>
</section>

<section class="principle">
  <div class="principle-label">the principle</div>
  <div class="principle-text">
    <p>The Goldilocks principle states that optimal performance occurs when things are neither too extreme nor too mild, but fall within a <em>"just right"</em> margin. The concept crosses multiple disciplines — from behavioural psychology to astronomy to economics.</p>
    <p>This tool applies the same logic to integration pipelines — mapping lineage, enabling traversal, surfacing structure that was always there but never visible.</p>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    padding: 4rem 0 3rem;
  }
  .left { display: flex; flex-direction: column; gap: 1.1rem; }
  .eyebrow {
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }
  h1 {
    font-size: 3.2rem;
    line-height: 1.05;
    font-weight: 700;
    margin: 0;
  }
  .accent { color: var(--sl-color-accent); }
  .tagline {
    font-size: .95rem;
    line-height: 1.7;
    color: var(--sl-color-gray-2);
    max-width: 340px;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--sl-font-mono);
    font-size: 13px;
    font-weight: 500;
    background: var(--sl-color-accent);
    color: #fff;
    padding: 10px 20px;
    border-radius: 6px;
    text-decoration: none;
    width: fit-content;
  }
  .terminal {
    background: #f7f5f0;
    border: 0.5px solid #d9d4c7;
    border-radius: 10px;
    overflow: hidden;
    font-family: var(--sl-font-mono);
  }
  .term-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    border-bottom: 0.5px solid #d9d4c7;
    background: #eeebe3;
  }
  .dot {
    width: 11px; height: 11px;
    border-radius: 50%;
    display: inline-block;
  }
  .red { background: #e06c6c; }
  .grey { background: #d9d4c7; }
  .gold { background: #b87333; }
  .term-title { font-size: 12px; color: #888; margin-left: 6px; }
  .term-body { padding: 1.2rem 1.4rem; font-size: 13px; line-height: 1.8; min-height: 200px; color: #333; }
  .term-footer {
    border-top: 0.5px solid #d9d4c7;
    padding: 8px 14px;
    font-size: 11px;
    letter-spacing: .08em;
    color: #aaa;
  }
  .principle {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    padding: 2.5rem 0;
    border-top: 0.5px solid var(--sl-color-gray-5);
  }
  .principle-label {
    font-family: var(--sl-font-mono);
    font-size: 11px;
    letter-spacing: .12em;
    color: var(--sl-color-accent);
    text-transform: uppercase;
    padding-top: 4px;
  }
  .principle-text p {
    font-size: .95rem;
    line-height: 1.8;
    color: var(--sl-color-gray-2);
    margin: 0 0 1rem;
  }
  .principle-text em {
    font-style: italic;
    color: var(--sl-color-white);
  }
  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; }
    .principle { grid-template-columns: 1fr; }
  }
</style>

<script>
const lines = [
  { text: '$ goldilocks fetch', class: 'cmd' },
  { text: '↳ fetching pipelines from org_aura_1...', class: 'dim' },
  { text: '↳ 3 pipelines · sanitising · anonymising', class: 'dim' },
  { text: '' },
  { text: '$ goldilocks visualise', class: 'cmd' },
  { text: 'org_pipeline_1', class: 'tree' },
  { text: '├── anon_snap_a (mapper)', class: 'tree' },
  { text: '├── anon_snap_b (http_client)', class: 'tree' },
  { text: '└── anon_snap_c (json_formatter)', class: 'tree' },
  { text: '' },
  { text: '$ goldilocks ask "what does this pipeline do?"', class: 'cmd' },
  { text: '🫧 maps auth tokens → calls external api → formats response', class: 'accent' },
];

const container = document.getElementById('termLines');
lines.forEach((line, i) => {
  setTimeout(() => {
    const el = document.createElement('div');
    el.textContent = line.text;
    el.style.cssText = `
      opacity: 0;
      transform: translateY(4px);
      transition: opacity .3s ease, transform .3s ease;
      color: ${line.class === 'dim' ? '#aaa' : line.class === 'accent' ? '#b87333' : '#333'};
      font-weight: ${line.class === 'cmd' ? '500' : '400'};
    `;
    container?.appendChild(el);
    requestAnimationFrame(() => {
      el.style.opacity = '1';
      el.style.transform = 'none';
    });
  }, i * 400);
});
</script>
